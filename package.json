{
  "name": "johnny-ai-assistant",
  "version": "2.1.0",
  "description": "Autonomer KI-Assistent v2.1 — NLP, Sensoren, Web-Autonomie, Enhanced Speech/Vision/Creative",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node tests/run.js",
    "test:filter": "node tests/run.js --filter",
    "build": "electron-builder",
    "build:jsx": "node build.js",
    "build:jsx:watch": "node build.js --watch",
    "install-ollama": "node scripts/install-ollama.js"
  },
  "build": {
    "appId": "com.johnny.ai.assistant",
    "productName": "Johnny AI Assistant",
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "files": [
      "**/*",
      "!agents/**/*",
      "!knowledge/**/*",
      "!data/**/*"
    ],
    "extraResources": [
      {
        "from": "agents",
        "to": "agents"
      },
      {
        "from": "knowledge",
        "to": "knowledge"
      }
    ]
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "express": "^4.18.2",
    "systeminformation": "^5.21.0",
    "node-telegram-bot-api": "^0.64.0",
    "markdown-it": "^14.0.0",
    "uuid": "^9.0.1",
    "chokidar": "^3.5.3",
    "ws": "^8.16.0",
    "node-fetch": "^3.3.2",
    "whatsapp-web.js": "^1.23.0",
    "qrcode-terminal": "^0.12.0",
    "discord.js": "^14.14.1",
    "@slack/bolt": "^3.17.0",
    "matrix-js-sdk": "^31.0.0",
    "nodemailer": "^6.9.0",
    "googleapis": "^128.0.0",
    "imap": "^0.8.19",
    "mailparser": "^3.6.5",
    "puppeteer": "^21.6.1",
    "cheerio": "^1.0.0-rc.12",
    "chromadb": "^1.7.3",
    "node-cron": "^3.0.3",
    "form-data": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.12.0",
    "mqtt": "^5.3.4"
  },
  "optionalDependencies": {
    "serialport": "^12.0.0",
    "@serialport/parser-readline": "^12.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.24.0"
  }
}